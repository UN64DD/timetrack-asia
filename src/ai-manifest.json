{
  "v": "1.0.0",
  "n": "Time Track Solutions",
  "o": "Modern sports event mgmt platform. Focus: running/ultra events. Registration + Logistics.",
  "tech": ["React", "Vite", "Supabase", "Tailwind", "Framer Motion"],
  "roles": {
    "RT": "Root. Supreme. Global user/db/sys control.",
    "AD": "Admin. Governance. Approve events, orders, analytics.",
    "OR": "Organizer. Ops. Create/edit events, variants, results.",
    "AT": "Athlete. End-user. Browse, register, pay, view results."
  },
  "feats": [
    "All-in-One: Events, reg, comms.",
    "Seamless: Easy sign-up, secure pay.",
    "Real-time: Live participant data.",
    "Auto: Dynamic scheduling/updates.",
    "Team: Profile/progress tracking.",
    "Scale: Small to intl races.",
    "Insight: Performance analytics.",
    "UX: intuitive interface for all."
  ],
  "routes": {
    "pub": ["/", "/events", "/about", "/results", "/contact", "/register/:id"],
    "auth": ["/login", "/signup", "/profile"],
    "dash": ["admin.domain/", "organizer.domain/", "developer.domain/"]
  },
  "theme": "Neobrutalist. Red/Blue/Black. High-contrast. Tactical."
}
